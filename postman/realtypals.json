{
  "info": {
    "name": "RealtyPals API",
    "_postman_id": "realtypals-v1",
    "description": "RealtyPals API — Sector 150 Noida property search and AI chat",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "user_id",  "value": "postman-test-user-001",        "type": "string" }
  ],
  "item": [
    {
      "name": "Sectors",
      "item": [
        {
          "name": "GET /sectors",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/sectors", "host": ["{{base_url}}"], "path": ["sectors"] }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "GET /projects — all Sector 150",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/projects?sector=Sector 150",
              "host": ["{{base_url}}"], "path": ["projects"],
              "query": [{ "key": "sector", "value": "Sector 150" }]
            }
          }
        },
        {
          "name": "GET /projects — 3BHK filter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/projects?sector=Sector 150&bhk=3",
              "host": ["{{base_url}}"], "path": ["projects"],
              "query": [{ "key": "sector", "value": "Sector 150" }, { "key": "bhk", "value": "3" }]
            }
          }
        },
        {
          "name": "GET /projects — budget under 3 Cr",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/projects?sector=Sector 150&max_price=30000000",
              "host": ["{{base_url}}"], "path": ["projects"],
              "query": [{ "key": "sector", "value": "Sector 150" }, { "key": "max_price", "value": "30000000" }]
            }
          }
        },
        {
          "name": "GET /projects — 3BHK under 3 Cr",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/projects?sector=Sector 150&bhk=3&max_price=30000000",
              "host": ["{{base_url}}"], "path": ["projects"],
              "query": [
                { "key": "sector", "value": "Sector 150" },
                { "key": "bhk", "value": "3" },
                { "key": "max_price", "value": "30000000" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "POST /chat — greeting",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",    "value": "{{user_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"message\": \"hi\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/chat", "host": ["{{base_url}}"], "path": ["chat"] }
          }
        },
        {
          "name": "POST /chat — full intent (returns projects)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",    "value": "{{user_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"message\": \"3BHK in Sector 150 under 3 crore end use\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/chat", "host": ["{{base_url}}"], "path": ["chat"] }
          }
        },
        {
          "name": "POST /chat — partial intent (asks for budget)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",    "value": "{{user_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"message\": \"3BHK in Sector 150\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/chat", "host": ["{{base_url}}"], "path": ["chat"] }
          }
        },
        {
          "name": "POST /chat — general query (RERA)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",    "value": "{{user_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"message\": \"what is RERA?\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/chat", "host": ["{{base_url}}"], "path": ["chat"] }
          }
        },
        {
          "name": "POST /chat — compare projects",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",    "value": "{{user_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"message\": \"compare ATS Kingston Heath vs Godrej Palm Retreat\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/chat", "host": ["{{base_url}}"], "path": ["chat"] }
          }
        },
        {
          "name": "POST /chat — wellness homes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",    "value": "{{user_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"message\": \"show me wellness focused projects in Sector 150\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/chat", "host": ["{{base_url}}"], "path": ["chat"] }
          }
        },
        {
          "name": "POST /chat — golf course view",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",    "value": "{{user_id}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"message\": \"4BHK with golf course view under 6 crore in Sector 150\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/chat", "host": ["{{base_url}}"], "path": ["chat"] }
          }
        },
        {
          "name": "DELETE /chat/intent — reset session",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-User-Id", "value": "{{user_id}}" }
            ],
            "url": { "raw": "{{base_url}}/chat/intent", "host": ["{{base_url}}"], "path": ["chat", "intent"] }
          }
        }
      ]
    }
  ]
}
