            }
        ],
    transparency_checks: [
            { label: 'RERA Registered', ok: true, details: 'Registered under UPRERAPRJ...'
            },
            { label: 'OC / CC Received', ok: true, details: 'Occupancy certificate received.'
            },
            { label: 'Escrow Account', ok: true, details: 'Verified with HDFC Bank.'
            }
        ],
    investment_insights: {
