─── CANONICAL SEED SCRIPT TEMPLATE ─────────────────────────────
Copy this template for every new project seed script. Replace ALL_CAPS placeholders.
import { PrismaClient
} from '@prisma/client'
const prisma = new PrismaClient()

async function seed() {
    // 1. Builder
  let builder = await prisma.builder.findFirst({ where: { name: 'BUILDER_NAME'
        }
    })
  const builderData = {
    name: 'BUILDER_NAME', slug: 'builder-slug',
    tagline: 'Builder tagline',
    company_overview: 'Full paragraph about builder history and track record.',
    founder: 'Founder Name', founded_year: 2010,
    delivered_units: 1500, projects_delivered_count: 18,
    rera_compliance_score: 90, delivery_score: 85,
    construction_quality_score: 88, buyer_satisfaction_score: 82,
    experience_years: '15+ Years', headquarters: 'Noida, UP',
    awards: ['Award 1'
        ], certifications: ['ISO 9001'
        ],
    }
  builder = builder
    ? await prisma.builder.update({ where: { id: builder.id
        }, data: builderData
    })
    : await prisma.builder.create({ data: builderData
    })

  // 2. Project
  let project = await prisma.project.findUnique({ where: { slug: 'PROJECT-SLUG'
        }
    })
  const projectData = {
    name: 'PROJECT NAME', slug: 'PROJECT-SLUG',
    builder: { connect: { id: builder.id
            }
        },
    city: 'Noida', sector: 'Sector XX',
    address: 'Plot No. X, Sector XX, Noida 201301',
    status: 'under_construction' as const,
    tagline: 'Project tagline',
    description: 'Short 1-2 sentence description used by AI.',
    long_description: 'Full multi-paragraph description of the project.',
    hero_image_url: '', // ← Add via admin panel Media section
    rera_number: 'UPRERAPRJXXXXXX',
    rera_url: 'https: //up-rera.in/...',  // ← Paste from UP RERA portal
    lat: 28.5, lng: 77.3,
    total_towers: 6, floors: 'G+28', total_units: 630,
    land_area_acres: 5.44, open_space_pct: 80,
    green_rating: 'IGBC Green Rated', project_type: 'Residential',
    has_duplex: false, has_penthouse: false,
    launch_date: new Date('2024-01-01'),
    possession_date: new Date('2028-12-01'),
    possession_label: 'December 2028',
    price_min_cr: 1.85, price_range_label: 'Rs 1.85 Cr - Rs 3.14 Cr+',
    architect: 'Architect Firm Name',
    interior_designer: 'Interior Design Firm',
    design_theme: 'Contemporary Art Deco',
    schools_nearby_count: 3, hospitals_nearby_count: 2,
    shopping_nearby_count: 3, it_parks_nearby_count: 2,
    banks_nearby_count: 1, restaurants_nearby_count: 5,
    marketing_claims: ['Claim 1', 'Claim 2', 'Claim 3'
        ],
    ai_search_keywords: ['keyword1', 'keyword2'
        ],
    escrow_verified: true, escrow_bank_name: 'HDFC Bank',
    registry_status: 'Active', project_risk_flag: null,
    }
  project = project
    ? await prisma.project.update({ where: { id: project.id
        }, data: projectData
    })
    : await prisma.project.create({ data: projectData
    })

  // 3. Project DNA
  const dnaData = {
    builder_track_record_score: 90, builder_track_record_label: 'Excellent',
    price_position_score: 85, price_position_label: 'Market Value',
    locality_score: 88, locality_label: 'Premium Enclave',
    rera_compliance_score: 95, rera_compliance_label: 'Fully Compliant',
    amenity_depth_score: 90, amenity_depth_label: 'Deep Resort',
    possession_certainty_score: 89, possession_certainty_label: 'On Schedule',
    last_verified_at: new Date(), verified_by: 'seed'
    }
  await prisma.projectDna.upsert({
    where: { project_id: project.id
        },
    create: { project_id: project.id, ...dnaData
        },
    update: dnaData
    })

  // 4. Decision Profile
  const intelligenceData = {
    topLevelMetrics: {
      overallScore: 88, tier: 'STRONG_BUY', investmentGrade: 'A',
      priceAdvantage: '+12%', priceAdvantageSubtext: 'Below Market',
      confidenceLevel: 'High', confidenceLabel: 'Highly Reliable'
        },
    dimensionScores: {
      builderTrust: { score: 92, status: 'Verified'
            },
      locationQuality: { score: 88, status: 'Verified'
            },
      lifestyleAmenities: { score: 90, status: 'Verified'
            },
      valueForMoney: { score: 85, status: 'Verified'
            },
      appreciationPotential: { score: 95, status: 'Verified'
            },
      legalSafety: { score: 95, status: 'Verified'
            }
        },
    buyerPersonas: [
            { type: 'Growing Families', stars: 5, headline: 'Safety and Space', reasons: ['Reason 1', 'Reason 2'
                ]
            },
            { type: 'Capital Investors', stars: 4, headline: 'Appreciation Play', reasons: ['Reason 1'
                ]
            }
        ],
    riskRadar: [
