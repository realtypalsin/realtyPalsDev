# ============================================================
# RealtyPals Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- REQUIRED TO BOOT (production) ----------------------
NODE_ENV=production
PORT=8080
ADMIN_PASSWORD=change_me_to_a_strong_password

# ---- Database (REQUIRED) --------------------------------
# From Supabase: Settings → Database → Connection string (Transaction pooler)
DATABASE_URL=postgresql://user:password@host:6543/dbname
# From Supabase: Connection string (Session pooler) for direct access
DIRECT_URL=postgresql://user:password@host:5432/dbname

# ---- AI Provider (at least one REQUIRED) ---------------
# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Groq (free) — get from https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Claude API (Anthropic) — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ---- AI Model Selection (optional, uses defaults) ------
# Main model (reasoning, comparison, detailed responses)
AI_MAIN_MODEL=gpt-4o
# Fallback model (if main provider fails)
AI_FALLBACK_MODEL=claude-3-5-sonnet-20241022
# Groq models for fast inference
GROQ_FAST_MODEL=mixtral-8x7b-32768
GROQ_SMART_MODEL=mixtral-8x7b-32768

# ---- Frontend & CORS (REQUIRED) -------------------------
# Your Vercel frontend URL (e.g., https://realtypals.vercel.app)
FRONTEND_URL=https://your-frontend.vercel.app

# ---- Webhook & Integration (optional, but recommended) -
# Lead webhook secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your_32_char_hex_string_here
# Lead webhook target (external CRM or webhook service)
WEBHOOK_URL=https://webhook.example.com/leads

# ---- Supabase Auth (REQUIRED) ---------------------------
# From Supabase: Settings → API → URL
SUPABASE_URL=https://your-project.supabase.co
# From Supabase: Settings → API → Service Role Key (server-side only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# From Supabase: Settings → API → Anon Public Key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Redis Cache (optional but recommended) -----------
# From Upstash: Console → Databases → select database → REST API
UPSTASH_REDIS_REST_URL=https://xxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_auth_token

# ---- Observability & Monitoring (optional) -----------
# Sentry error tracking — get from https://sentry.io
SENTRY_DSN=https://xxxxx@sentry.io/1234567

# ---- WhatsApp Notifications (choose one) ---------------
# Options: 'meta' (Meta Cloud API), 'twilio' (Twilio), 'none'
WHATSAPP_PROVIDER=none

# Option A: Meta WhatsApp Cloud API
# From Meta: https://developers.facebook.com → WhatsApp → API Setup
META_WHATSAPP_TOKEN=EAA...
META_PHONE_NUMBER_ID=12345...
META_RECIPIENT_NUMBER=919876543210

# Option B: Twilio WhatsApp Sandbox (easier to test)
# From Twilio: https://console.twilio.com → WhatsApp Sandbox
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=auth_token_here
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_TO=+919876543210

# ---- Email Notifications (optional) -----------------
# Resend — free tier: 100 emails/day. Get from https://resend.com
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=leads@yourdomain.com
EMAIL_TO=sales@yourdomain.com

# ---- External APIs (optional, for search features) ---
# Google Maps API key for commute/location features
GOOGLE_MAPS_API_KEY=AIzaSy...
# Tavily for web search (https://tavily.com)
TAVILY_API_KEY=tvly-...
# Serper for fast web search fallback (https://serper.dev)
SERPER_API_KEY=xxxx...
# Jina Reader for webpage extraction (https://jina.ai)
JINA_API_KEY=jina_...

# ---- Feature Flags & Calculations (optional) --------
# Default city for recommendations
DEFAULT_CITY=Noida
# Default EMI interest rate (%)
EMI_RATE=8.5
# Default loan tenure (years)
LOAN_TENURE=20
# Logging verbosity (error, warn, info, debug)
LOG_LEVEL=info
# AI response token ceiling (safety guard)
MAX_TOKENS_RESPONSE=2000
# AI token safety limit
SAFE_TOKEN_CEILING=20000
