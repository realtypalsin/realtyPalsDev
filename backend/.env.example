# ============================================================
# RealtyPals Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Server ------------------------------------------------
NODE_ENV=production
PORT=8080

# ---- Security ----------------------------------------------
# Shared secret between frontend and this backend
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your_32_char_secret_here

# ---- CORS --------------------------------------------------
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ---- WhatsApp Notifications --------------------------------
# Set WHATSAPP_PROVIDER to: meta | twilio | none
WHATSAPP_PROVIDER=none

# Option A: Meta WhatsApp Cloud API (free tier available)
# Get from: https://developers.facebook.com/apps → WhatsApp → API Setup
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_RECIPIENT_NUMBER=91XXXXXXXXXX   # Your sales team's WhatsApp number (with country code)

# Option B: Twilio WhatsApp Sandbox (easier to test)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886    # Twilio sandbox number
TWILIO_WHATSAPP_TO=+91XXXXXXXXXX    # Your sales team's WhatsApp number

# ---- Email Notifications (optional) -----------------------
# Resend — free tier: 100 emails/day. Sign up: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=leads@yourdomain.com
EMAIL_TO=sales@yourdomain.com
