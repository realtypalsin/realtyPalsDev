{
  "name": "realtypals-backend",
  "version": "1.0.0",
  "description": "RealtyPals backend service — lead processing and notifications",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "prisma migrate deploy --schema=../frontend/prisma/schema.prisma && node dist/index.js",
    "test": "node --require tsx/cjs --test src/lib/**/__tests__/*.test.ts",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "db:generate": "prisma generate --schema=../frontend/prisma/schema.prisma",
    "postinstall": "prisma generate --schema=../frontend/prisma/schema.prisma",
    "typecheck": "tsc --noEmit",
    "check-all": "npm run lint && npm run typecheck"
  },
  "prisma": {
    "schema": "../frontend/prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@prisma/client": "^5.20.0",
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.49.8",
    "@upstash/redis": "^1.38.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "file-type": "^16.5.4",
    "groq-sdk": "^0.7.0",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.2",
    "openai": "^6.42.0",
    "pino": "^9.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.12",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^8.57.1",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
