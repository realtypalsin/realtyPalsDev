{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://realtypalsdev.onrender.com/api/:path*"
    }
  ],
  "buildCommand": "npm run db:generate && npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "app/api/v1/chat/route.ts": {
      "maxDuration": 60
    }
  }
}
