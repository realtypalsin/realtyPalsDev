generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Builder {
  id                 String    @id @default(uuid())

  // Identity
  name               String    @unique
  slug               String    @unique
  tagline            String?
  founder            String?
  company_overview   String?
  logo_url           String?
  parent_group       String?
  founded_year       Int?
  headquarters       String?
  website            String?
  email              String?
  phone              String?
  description        String?

  // Track Record
  total_projects_count      Int?
  delivered_units           Int?
  delivered_projects        String[]
  ongoing_projects          String[]
  delayed_projects_count    Int?
  average_delay_months      Float?
  delivery_score            Int?

  // Quality (0-100 admin-set scores)
  construction_quality_score Int?
  after_sales_score          Int?
  buyer_satisfaction_score   Int?

  // Compliance
  rera_compliance_score      Int?
  litigation_count           Int?
  insolvency_history         Boolean   @default(false)
  legal_flag                 String?

  // Market Position
  luxury_specialization      Boolean   @default(false)
  township_specialization    Boolean   @default(false)
  affordable_specialization  Boolean   @default(false)
  average_project_size       Int?

  // Recognition
  awards                     String[]
  awards_count               Int?
  certifications             String[]
  credai_member              Boolean   @default(false)
  iso_certified              Boolean   @default(false)

  // Confidence
  verification_level         String?
  last_verified_at           DateTime?
  data_source                String?
  intelligence_completeness  Int?

  created_at                 DateTime  @default(now())
  projects                   Project[]

  @@map("builders")
}

model Project {
  id                       String                 @id @default(uuid())
  slug                     String                 @unique
  name                     String
  tagline                  String?
  builder_id               String
  rera_number              String?
  rera_url                 String?
  city                     String                 @default("Noida")
  sector                   String
  address                  String?
  lat                      Float?
  lng                      Float?
  land_area_acres          Float?
  total_units              Int?
  total_towers             Int?
  status                   ProjectStatus
  launch_date              DateTime?
  possession_date          DateTime?
  possession_label         String?
  description              String?
  long_description         String?
  design_theme             String?
  architect                String?
  interior_designer        String?
  marketing_claims         String[]
  ai_search_keywords       String[]
  hero_image_url           String?
  created_at               DateTime               @default(now())
  updated_at               DateTime               @updatedAt
  embedding                Unsupported("vector")?
  project_risk_flag        String?
  amenities                Amenity[]
  connectivity             Connectivity[]
  decision_profile         DecisionProfile?
  persona_profile          PersonaProfile?
  referenced_as_competitor ProjectCompetitor[]    @relation("CompetitorProject")
  competitors              ProjectCompetitor[]    @relation("SourceProject")
  dna                      ProjectDna?
  images                   ProjectImage[]
  builder                  Builder                @relation(fields: [builder_id], references: [id])
  recommendation_profile   RecommendationProfile?
  saved_by                 SavedProperty[]
  unit_types               UnitType[]
  payment_plan             PaymentPlan?
  cost_sheet               CostSheet?

  @@index([city, sector])
  @@index([status])
  @@index([possession_date])
  @@index([builder_id])
  @@map("projects")
}

model ProjectDna {
  id                         String    @id @default(uuid())
  project_id                 String    @unique
  builder_track_record_score Int?
  builder_track_record_label String?
  price_position_score       Int?
  price_position_label       String?
  locality_score             Int?
  locality_label             String?
  rera_compliance_score      Int?
  rera_compliance_label      String?
  amenity_depth_score        Int?
  amenity_depth_label        String?
  possession_certainty_score Int?
  possession_certainty_label String?
  last_verified_at           DateTime?
  verified_by                String?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt
  project                    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_dna")
}

model DecisionProfile {
  id                   String             @id @default(uuid())
  project_id           String             @unique
  status               IntelligenceStatus @default(DRAFT)
  decision_thesis      String?
  why_buy              String[]           @default([])
  why_avoid            String[]           @default([])
  best_for             String?
  not_ideal_for        String?
  confidence_sources   String[]           @default([])
  recommendation_notes String?
  advisor_notes        String?
  last_verified_at     DateTime?
  verified_by          String?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  project              Project            @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("decision_profiles")
}

model PersonaProfile {
  id                 String    @id @default(uuid())
  project_id         String    @unique
  primary_persona    String?
  secondary_personas String[]  @default([])
  persona_descriptions Json?
  income_range       String?
  family_stage       String?
  work_location      String?
  risk_appetite      String?
  timeline_horizon   String?
  motivation_note    String?
  last_verified_at   DateTime?
  verified_by        String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  project            Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("persona_profiles")
}

model RecommendationProfile {
  id                   String             @id @default(uuid())
  project_id           String             @unique
  status               IntelligenceStatus @default(DRAFT)
  tier                 String?
  primary_thesis       String?
  end_use_thesis       String?
  investment_thesis    String?
  family_thesis        String?
  investor_thesis      String?
  luxury_thesis        String?
  risk_thesis          String?
  walk_away_conditions String[]           @default([])
  timeline_advice      String?
  negotiation_leverage String[]           @default([])
  internal_confidence  String?
  admin_notes          String?
  last_verified_at     DateTime?
  verified_by          String?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  project              Project            @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("recommendation_profiles")
}

model ProjectCompetitor {
  id                     String    @id @default(uuid())
  project_id             String
  competitor_project_id  String?
  competitor_name        String
  competitor_slug        String?
  this_project_advantage String?
  competitor_advantage   String?
  verdict                String?
  price_delta_note       String?
  sort_order             Int       @default(0)
  last_verified_at       DateTime?
  verified_by            String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  competitor_project     Project?  @relation("CompetitorProject", fields: [competitor_project_id], references: [id])
  project                Project   @relation("SourceProject", fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@map("project_competitors")
}

model IntelligenceAudit {
  id          String   @id @default(uuid())
  project_id  String
  section     String
  action      String
  before_data Json?
  after_data  Json?
  created_by  String?
  created_at  DateTime @default(now())

  @@index([project_id])
  @@index([project_id, section])
  @@map("intelligence_audits")
}

model UnitType {
  id                 String   @id @default(uuid())
  project_id         String
  name               String
  bhk                Int
  super_area_sqft    Int?
  carpet_area_sqft   Int?
  balcony_area_sqft  Int?
  bathrooms          Int?
  utility_room       Boolean  @default(false)
  dress_area         Boolean  @default(false)
  towers             String[]
  price_min_cr       Float?
  price_max_cr       Float?
  price_label        String?
  price_is_estimated Boolean  @default(true)
  project            Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id, bhk])
  @@index([project_id, price_min_cr, price_max_cr])
  @@map("unit_types")
}

model ProjectImage {
  id         String    @id @default(uuid())
  project_id String
  url        String
  type       ImageType
  caption    String?
  bhk        Int?
  size_sqft  Int?
  sort_order Int       @default(0)
  project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id, type])
  @@map("project_images")
}

model Amenity {
  id         String          @id @default(uuid())
  project_id String
  name       String
  category   AmenityCategory
  project    Project         @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@map("amenities")
}

model Connectivity {
  id          String           @id @default(uuid())
  project_id  String
  type        ConnectivityType
  name        String
  distance_km Float?
  data_source DataSource       @default(brochure)
  notes       String?
  project     Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@map("connectivity")
}

model ChatSession {
  id            String        @id @default(uuid())
  user_id       String?
  guest_token   String?
  title         String?
  message_count Int           @default(0)
  created_at    DateTime      @default(now())
  last_active   DateTime      @default(now())
  chat_phase    String        @default("DISCOVERY")
  last_projects Json?
  summary       String?
  messages      ChatMessage[]

  @@index([user_id])
  @@index([guest_token])
  @@map("chat_sessions")
}

model ChatMessage {
  id              String      @id @default(uuid())
  session_id      String
  role            MessageRole
  content         String
  intent_snapshot Json?
  created_at      DateTime    @default(now())
  artifacts       Json?
  session         ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id, created_at])
  @@map("chat_messages")
}

model UserMemory {
  id                     String   @id @default(uuid())
  user_id                String?  @unique
  bhk_preference         Int?
  budget_min_cr          Float?
  budget_max_cr          Float?
  sector_preference      String?
  purpose                String?
  possession_pref        String?
  viewed_slugs           String[]
  rejected_slugs         String[]
  saved_slugs            String[]
  summary_text           String?
  updated_at             DateTime @updatedAt
  work_location          String?
  home_loan_pre_approved Boolean?
  timeline_months        Int?
  contact_phone          String?
  guest_token            String?  @unique

  @@map("user_memory")
}

model SavedProperty {
  id         String   @id @default(uuid())
  user_id    String
  project_id String
  saved_at   DateTime @default(now())
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([user_id, project_id])
  @@index([user_id])
  @@map("saved_properties")
}

model SiteVisitRequest {
  id           String          @id @default(uuid())
  project_id   String
  project_slug String
  project_name String
  name         String
  phone        String
  email        String?
  visit_date   DateTime
  time_slot    String
  message      String?
  created_at   DateTime        @default(now())
  status       SiteVisitStatus @default(pending)

  @@index([project_slug])
  @@map("site_visit_requests")
}

model CallbackRequest {
  id           String   @id @default(uuid())
  name         String
  phone        String
  project_name String?
  project_slug String?
  user_id      String?
  guest_token  String?
  status       String   @default("new")
  created_at   DateTime @default(now())

  @@index([project_slug])
  @@map("callback_requests")
}

model PriceAlert {
  id              String   @id @default(uuid())
  user_id         String?
  guest_token     String?
  project_id      String
  project_slug    String
  target_price_cr Float
  notified        Boolean  @default(false)
  created_at      DateTime @default(now())

  @@index([project_slug])
  @@map("price_alerts")
}

model ProjectDocument {
  id           String   @id @default(uuid())
  project_id   String
  project_slug String
  name         String
  storage_url  String
  content_text String?
  doc_type     String   @default("brochure")
  file_size_bytes Int?
  created_at   DateTime @default(now())

  @@index([project_slug])
  @@map("project_documents")
}

enum ProjectStatus {
  under_construction
  ready_to_move
  new_launch
}

enum ImageType {
  hero
  exterior
  interior
  floor_plan
  amenity
  master_plan
  clubhouse
  pool
  location_map
}

enum AmenityCategory {
  sports
  lifestyle
  wellness
  kids
  security
  parking
}

enum ConnectivityType {
  metro
  road
  expressway
  school
  hospital
  mall
  landmark
  airport
  university
}

model PaymentPlan {
  id              String   @id @default(uuid())
  project_id      String   @unique
  plan_name       String?
  milestones      Json     @default("[]")
  source          String?
  source_url      String?
  verified_at     DateTime?
  verified_by     String?
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  project         Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("payment_plans")
}

model CostSheet {
  id                    String   @id @default(uuid())
  project_id            String   @unique
  base_price_per_sqft   Float?
  floor_rise_per_floor  Float?
  plc_charges           Json     @default("[]")
  parking_cost          Float?
  ifms                  Float?
  club_membership       Float?
  other_charges         Json     @default("[]")
  gst_rate_pct          Float    @default(5.0)
  stamp_duty_pct        Float    @default(6.0)
  registration_pct      Float    @default(1.0)
  assumptions           String[]
  verified_at           DateTime?
  verified_by           String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  project               Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("cost_sheets")
}

enum DataSource {
  brochure
  google
  estimated
  manual
}

enum MessageRole {
  user
  assistant
}

enum IntelligenceStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
}

enum SiteVisitStatus {
  pending
  confirmed
  cancelled
  completed
}
