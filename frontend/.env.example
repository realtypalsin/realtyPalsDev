# ── Database ──────────────────────────────────────────────────────────
# Supabase connection pooler (use port 6543 for Vercel serverless)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase direct connection (for migrations only)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ── Supabase ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="eyJ..."   # anon/public key from Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY="eyJ..."              # service_role key (NEVER expose client-side)

# ── AI / Chat ─────────────────────────────────────────────────────────
GROQ_API_KEY="gsk_..."                           # Groq console: console.groq.com
# Optional providers (not required for MVP)
# ANTHROPIC_API_KEY="sk-ant-..."
# CEREBRAS_API_KEY="..."
# COHERE_API_KEY="..."

# ── Search ─────────────────────────────────────────────────────────────
TAVILY_API_KEY="tvly-..."                        # app.tavily.com
JINA_API_KEY="jina_..."                          # jina.ai

# ── Cache ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL="https://...upstash.io"       # console.upstash.com
UPSTASH_REDIS_TOKEN="..."

# ── Google Maps ──────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY="AIza..."                    # Server-side (never expose)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIza..."        # Client-side (restrict to your domain)

# ── WhatsApp ────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="919XXXXXXXXX"       # Format: 91 + 10-digit number

# ── Admin ────────────────────────────────────────────────────────────
ADMIN_SECRET="your-strong-secret-here"
ADMIN_PASSWORD="your-strong-password-here"

# ── Analytics / Monitoring ──────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_..."               # app.posthog.com
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
SENTRY_DSN="https://...@sentry.io/..."          # sentry.io (optional)
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."

# ── App URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://realty-pals-dev-frontend-three.vercel.app"

# ── Optional ─────────────────────────────────────────────────────────
WAQI_TOKEN="..."                                 # waqi.info — for AQI data
CHAT_PROVIDER="groq"                             # groq | anthropic | bedrock

# ── Backend (Render) Webhook ────────────────────────────────────────
# Set AFTER deploying backend to Render
LEAD_WEBHOOK_URL="https://your-backend.onrender.com/api/leads/webhook"
# Must match WEBHOOK_SECRET in backend/.env
LEAD_WEBHOOK_SECRET="your-32-char-secret-here"
