{
  "name": "realtypals-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "cd frontend && npm run db:generate && npm run build",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:studio": "cd frontend && npx prisma studio",
    "db:migrate": "cd frontend && npx prisma migrate dev",
    "db:push": "cd frontend && npx prisma db push",
    "db:generate": "cd frontend && npx prisma generate",
    "db:seed": "cd frontend && npm run db:seed",
    "doctor": "npx react-doctor@latest"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.33",
    "caniuse-lite": "^1.0.30001793",
    "eslint-plugin-react-hooks": "^7.1.1"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
